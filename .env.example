# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sign-In Web client ID (Firebase Console → Authentication → Google → Web SDK)
# GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional Firebase overrides for web builds (Vercel Environment Variables).
# Leave empty to use lib/firebase_options.dart (FlutterFire defaults).
# FIREBASE_API_KEY=
# FIREBASE_APP_ID=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_DATABASE_URL=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MEASUREMENT_ID=
